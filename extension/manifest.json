{
  "manifest_version": 3,
  "name": "Prompt Vault Collector",
  "version": "0.6.1",
  "description": "Save selected text, organize prompts and notes, search the vault, and insert prompts into AI input boxes.",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting", "tabs", "clipboardWrite", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Prompt Vault" },
  "side_panel": { "default_path": "sidepanel.html" }
}
